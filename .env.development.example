# Loaded in `vite` dev (with .env). Copy to `.env.development.local` (gitignored).
# Umami for local dev — set IDs in your Umami dashboard; do not commit real values.

# Required for Umami in dev (in addition to VITE_UMAMI_URL in `.env` unless you set URL below):
# VITE_UMAMI_WEBSITE_ID_DEV=

# Optional: different Umami host in dev (otherwise use VITE_UMAMI_URL from `.env`):
# VITE_UMAMI_URL_DEV=
