{
  "name": "neotoma",
  "version": "0.9.1",
  "description": "MCP server for structured personal data memory with unified source ingestion",
  "main": "dist/index.js",
  "type": "module",
  "browser": false,
  "exports": {
    ".": "./dist/index.js",
    "./core": "./dist/core/operations.js",
    "./core/operations": "./dist/core/operations.js",
    "./server": "./dist/server.js"
  },
  "bin": {
    "neotoma": "dist/cli/bootstrap.js"
  },
  "scripts": {
    "pretest": "npm run build:server",
    "build": "npm run build:server",
    "build:server": "tsc && node scripts/copy_pdf_worker_wrapper.js && npm run build:scripts",
    "build:scripts": "tsc -p tsconfig.scripts.json",
    "build:inspector": "node scripts/build_inspector.js",
    "prepublishOnly": "npm run build:server && npm run build:inspector",
    "pack:local": "node -e \"require('fs').rmSync('dist', { recursive: true, force: true })\" && npm run build:server && npm run build:inspector && npm pack --pack-destination .",
    "build:inspector:watch-target": "cross-env VITE_PUBLIC_BASE_PATH=/inspector/ NEOTOMA_INSPECTOR_OUT_DIR=../dist/inspector npm --prefix inspector run build:vite",
    "build:inspector:watch-target:prod": "cross-env VITE_PUBLIC_BASE_PATH=/inspector/ NEOTOMA_INSPECTOR_OUT_DIR=../dist/inspector VITE_NEOTOMA_ENV=prod npm --prefix inspector run build:vite",
    "prebuild:ui": "tsx scripts/repo_info.ts",
    "build:ui": "vite build",
    "prewatch:ui": "tsx scripts/repo_info.ts",
    "start:mcp": "node dist/index.js",
    "start:mcp:dev-shim": "node dist/mcp_dev_shim.js",
    "watch": "tsx watch src/index.ts",
    "watch:server": "node scripts/run-dev-task.js tsx watch src/actions.ts",
    "watch:ui": "node scripts/run-dev-task.js vite",
    "watch:dev:tunnel": "cross-env HTTP_PORT=3080 TUNNEL_NONINTERACTIVE=1 npx concurrently --kill-others-on-fail --restart-tries=0 --timestamp='HH:mm:ss' --prefix='{time} [{name}]' --names='tunnel,api   ' 'bash scripts/setup-https-tunnel.sh' 'bash scripts/run-dev-server-with-tunnel-url.sh'",
    "watch:server+api": "node scripts/pick-port.js 3080 -- cross-env TUNNEL_NONINTERACTIVE=1 npx concurrently --kill-others-on-fail --restart-tries=0 --timestamp='HH:mm:ss' --prefix='{time} [{name}]' --names='tunnel,api   ,build ' 'bash scripts/setup-https-tunnel.sh' 'bash scripts/run-dev-server-with-tunnel-url.sh' 'tsc --watch --preserveWatchOutput'",
    "watch:dev": "npm run watch:server+api",
    "watch:mcp:dev-shim": "tsx src/mcp_dev_shim.ts",
    "watch:mcp:stdio": "tsx watch src/index.ts",
    "watch:mcp:stdio:prod": "cross-env NEOTOMA_ENV=production tsx watch src/index.ts",
    "watch:prod": "node scripts/pick-port.js 3180 -- cross-env NEOTOMA_ENV=production npx concurrently --kill-others-on-fail=false --restart-tries=0 --timestamp='HH:mm:ss' --prefix='{time} [{name}]' --names='api   ,build' 'tsx watch src/actions.ts' 'tsc --watch --preserveWatchOutput'",
    "watch:prod:tunnel": "node scripts/pick-port.js 3180 -- cross-env NEOTOMA_ENV=production TUNNEL_NONINTERACTIVE=1 npx concurrently --kill-others-on-fail --restart-tries=0 --timestamp='HH:mm:ss' --prefix='{time} [{name}]' --names='tunnel,api   ,build' 'bash scripts/setup-https-tunnel.sh' 'bash scripts/run-dev-server-with-tunnel-url.sh' 'tsc --watch --preserveWatchOutput'",
    "watch:inspector": "cross-env VITE_PUBLIC_BASE_PATH=/inspector/ NEOTOMA_INSPECTOR_OUT_DIR=../dist/inspector npm --prefix inspector run build:watch",
    "watch:inspector:prod": "cross-env VITE_PUBLIC_BASE_PATH=/inspector/ NEOTOMA_INSPECTOR_OUT_DIR=../dist/inspector VITE_NEOTOMA_ENV=prod npm --prefix inspector run build:watch",
    "watch:full": "npm run build:inspector:watch-target && node scripts/pick-port.js --print-resources 3080 5195 3001 -- cross-env NEOTOMA_INSPECTOR_LIVE_BUILD=1 npx concurrently --kill-others-on-fail=false --restart-tries=0 --timestamp='HH:mm:ss' --prefix='{time} [{name}]' --prefix-colors='blue,green,magenta,yellow,cyan' --names='server,app  ,build ,links ,insp ' 'npm run watch:server' 'npm run watch:ui' 'tsc --watch --preserveWatchOutput' 'npm run dev:resources:watch' 'npm run watch:inspector'",
    "watch:full:prod": "npm run build:inspector:watch-target:prod && node scripts/pick-port.js --print-resources 3180 5295 3101 -- cross-env NEOTOMA_ENV=production NEOTOMA_INSPECTOR_LIVE_BUILD=1 npx concurrently --kill-others-on-fail=false --restart-tries=0 --timestamp='HH:mm:ss' --prefix='{time} [{name}]' --prefix-colors='blue,green,magenta,yellow,cyan' --names='server,app  ,build ,links ,insp ' 'npm run watch:server' 'npm run watch:ui' 'tsc --watch --preserveWatchOutput' 'npm run dev:resources:watch' 'npm run watch:inspector:prod'",
    "dev": "npm run watch",
    "dev:ui": "npm run watch:ui",
    "dev:server": "npm run watch:server",
    "dev:api": "npm run watch:dev:tunnel",
    "dev:server+api": "npm run watch:server+api",
    "dev:resources": "node scripts/show-dev-resources.js",
    "dev:resources:watch": "node scripts/show-dev-resources.js --watch",
    "dev:server+mcp": "node scripts/pick-port.js 3080 8280 --vars HTTP_PORT,MCP_HTTP_PORT -- cross-env npx concurrently --kill-others-on-fail=false --restart-tries=0 --timestamp='HH:mm:ss' --prefix='{time} [{name}]' --names='api   ,mcp   ,build ' 'tsx watch src/actions.ts' 'node dist/index.js' 'tsc --watch --preserveWatchOutput'",
    "dev:mcp:dev-shim": "npm run watch:mcp:dev-shim",
    "dev:mcp:stdio": "npm run watch:mcp:stdio",
    "dev:mcp:stdio:prod": "npm run watch:mcp:stdio:prod",
    "dev:mcp:watch": "tsc --watch --preserveWatchOutput",
    "watch:build": "tsc --watch --preserveWatchOutput",
    "dev:prod": "npm run watch:prod",
    "test": "vitest run",
    "test:unit": "cross-env VITEST_SKIP_MIGRATIONS=1 vitest run",
    "test:frontend": "cross-env RUN_FRONTEND_TESTS=1 vitest run frontend/src",
    "test:integration": "vitest run tests/integration",
    "eval:tier1": "vitest run tests/integration/agentic_eval_matrix.test.ts",
    "eval:tier1:update": "cross-env UPDATE_AGENTIC_EVAL_SNAPSHOTS=1 vitest run tests/integration/agentic_eval_matrix.test.ts",
    "test:remote:critical": "cross-env RUN_REMOTE_TESTS=1 vitest run tests/integration/mcp_actions_matrix.test.ts tests/integration/mcp_resources.test.ts tests/integration/mcp_store_unstructured.test.ts tests/integration/mcp_store_parquet.test.ts tests/integration/mcp_schema_actions.test.ts tests/integration/schema_recommendation_integration.test.ts tests/integration/observation_ingestion.test.ts tests/integration/relationship_snapshots.test.ts tests/services/auto_enhancement_converter_detection.test.ts tests/services/auto_enhancement_processor.test.ts",
    "test:contract": "vitest run tests/contract",
    "test:cross-layer": "vitest run tests/integration/cli_to_mcp_store.test.ts tests/integration/cli_to_mcp_entities.test.ts tests/integration/cli_to_mcp_relationships.test.ts tests/integration/cli_to_mcp_schemas.test.ts",
    "test:parity": "vitest run tests/contract/contract_mcp_cli_parity.test.ts",
    "test:e2e:coverage": "npm run test:contract && npm run test:cross-layer",
    "test:agent-mcp": "vitest run tests/agent",
    "test:coverage": "vitest run --coverage",
    "test:coverage:critical": "vitest run --coverage src/services/entity_resolution.ts src/services/event_generation.ts src/services/graph_builder.ts src/services/file_analysis.ts src/services/search.ts",
    "migrate": "node scripts/run_migrations.js",
    "migrate:dry-run": "node scripts/run_migrations.js --dry-run",
    "migrate:plans": "tsx scripts/migrate_plans.ts",
    "migrate:plans:dry-run": "tsx scripts/migrate_plans.ts --dry-run",
    "recover:db": "node scripts/recover_sqlite_database.js",
    "recover:db:prod": "node scripts/recover_sqlite_database.js --env production",
    "lint": "eslint src --ext .ts",
    "lint:site-copy": "tsx scripts/lint_site_copy_style.ts",
    "type-check": "tsc --noEmit",
    "start:api": "node dist/actions.js",
    "start:api:prod": "npm run build:server && node scripts/pick-port.js 3180 -- cross-env NEOTOMA_ENV=production node dist/actions.js",
    "dev:full": "npm run watch:full",
    "dev:full:prod": "npm run watch:full:prod",
    "dev:serve": "node scripts/run-dev-task.js node scripts/dev-serve.js",
    "branches:prune": "node scripts/prune-merged-branches.js",
    "start:ws": "node dist/mcp_ws_bridge.js",
    "dev:ws": "node scripts/pick-port.js 3080 8280 --vars HTTP_PORT,WS_PORT -- cross-env tsx watch src/mcp_ws_bridge.ts",
    "test:e2e": "cross-env PLAYWRIGHT_USE_MOCK_API=1 PLAYWRIGHT_TEST_SEED=ci npx playwright test",
    "test:e2e:headed": "cross-env PLAYWRIGHT_USE_MOCK_API=1 PLAYWRIGHT_TEST_SEED=ci npx playwright test --headed",
    "validate:coverage": "tsx scripts/validate-coverage-map.ts",
    "check:pw-coverage": "tsx scripts/check-playwright-coverage.ts",
    "validate:doc-deps": "node scripts/validate-doc-dependencies.js --check-modified",
    "doctor": "tsx scripts/doctor.ts",
    "schema:export": "tsx scripts/export_schema_snapshots.ts",
    "embeddings:backfill": "tsx scripts/backfill_entity_embeddings.ts",
    "schema:init": "tsx scripts/initialize-schemas.ts",
    "schema:init:dry-run": "tsx scripts/initialize-schemas.ts --dry-run",
    "schema:icons:generate": "tsx scripts/generate_schema_icons.ts",
    "schema:icons:generate:dry-run": "tsx scripts/generate_schema_icons.ts --dry-run",
    "schema:cleanup:test": "tsx scripts/cleanup_test_schemas.ts",
    "schema:cleanup:test:dry-run": "tsx scripts/cleanup_test_schemas.ts --dry-run",
    "schema:cleanup:test:mark-only": "tsx scripts/cleanup_test_schemas.ts --mark-only",
    "feedback:seed-schema": "tsx scripts/seed_product_feedback_schema.ts",
    "feedback:mirror-backfill": "tsx scripts/feedback_mirror_backfill.ts",
    "docs:generate": "tsx src/services/documentation_generator.ts",
    "build:pages:site": "tsx --tsconfig frontend/tsconfig.json scripts/build_github_pages_site.tsx",
    "watch:pages:site": "node scripts/watch_site.js",
    "dev:pages:site": "npx concurrently --kill-others-on-fail=false --names 'build,serve' 'npm run watch:pages:site' 'npx serve site_pages -p 4000'",
    "docs:build": "vite build --config vite.config.ts",
    "docs:dev": "vite --config vite.config.ts",
    "docs:serve": "node scripts/serve-docs-react.js",
    "openapi:generate": "openapi-typescript ./openapi.yaml --default-non-nullable false -o src/shared/openapi_types.ts",
    "openapi:bc-diff": "node scripts/openapi_bc_diff.js",
    "cli": "node dist/cli/index.js",
    "cli:dev": "tsx src/cli/index.ts",
    "setup:cli": "npm run build:server && npm link && node -e \"const cp=require('child_process'); const fs=require('fs'); const p=cp.execSync('npm config get prefix',{encoding:'utf8'}).trim(); const bin=p+'/bin'; const neotomaPath=bin+'/neotoma'; const exists=fs.existsSync(neotomaPath); console.log(''); console.log('Step 1: Run this in your terminal (or add to ~/.zshrc):'); console.log('  export PATH=\\\"' + bin + ':\\$PATH\\\"'); console.log(''); console.log('Step 2: Then run: neotoma'); if(exists) { console.log(''); console.log('(Verified: neotoma is linked at ' + neotomaPath + ')'); }\"",
    "prepare": "husky || node -e \"process.exit(0)\"",
    "setup:cursor": "bash scripts/setup_cursor_from_foundation.sh",
    "setup:claude": "bash scripts/setup_claude_instructions.sh",
    "sync:mcp": "node scripts/sync_mcp_configs.js",
    "setup:env-hook": "bash scripts/setup-env-copy-hook.sh",
    "setup:launchd-dev": "node scripts/install_launchd_dev_servers.js",
    "setup:launchd-watch-build": "node scripts/install_launchd_watch_build.js",
    "copy:env": "node scripts/copy-env-to-worktree.js",
    "tunnel:https": "bash scripts/setup-https-tunnel.sh",
    "setup:worktree": "bash scripts/cursor-worktree-init.sh",
    "setup:data": "node scripts/setup-data-symlink.js",
    "setup:foundation": "node scripts/setup-foundation-symlink.js",
    "wipe:dev": "node scripts/wipe-local-database.js",
    "wipe:prod": "node scripts/wipe-local-database.js --env production",
    "wipe:prod:storage": "node scripts/wipe-local-database.js --env production --storage",
    "wipe:local": "node scripts/wipe-local-database.js",
    "wipe:local:storage": "node scripts/wipe-local-database.js --storage",
    "wipe:local:prod": "node scripts/wipe-local-database.js --env production",
    "parquet:samples": "bash scripts/create_sample_parquet_files_simple.sh",
    "wipe:dev:storage": "node scripts/wipe-local-database.js --storage",
    "analyze:schemas": "node scripts/analyze-data-dir-schemas.js",
    "ingest:data-dir": "npx tsx scripts/ingest_data_dir.ts",
    "sync:env": "bash scripts/sync-env-from-1password.sh",
    "debug:errors:cli": "node scripts/trigger_error_debug_cli.js",
    "monitor:snapshots": "tsx scripts/monitor_and_fix_snapshots.ts",
    "check:snapshots": "tsx scripts/check_stale_snapshots.ts",
    "check:timeline": "tsx scripts/check_timeline_health.ts",
    "backfill:timeline": "tsx scripts/backfill_timeline_via_recompute.ts",
    "simulate:install": "node scripts/simulate_npm_install.js",
    "check:bundlephobia": "node scripts/check_bundlephobia.js",
    "validate:locales": "tsx --tsconfig frontend/tsconfig.json scripts/validate_locale_parity.ts",
    "validate:routes": "tsx scripts/validate_site_route_parity.ts",
    "validate:site-export": "tsx scripts/validate_site_export.ts",
    "release-notes:render": "tsx scripts/render_github_release_notes.ts",
    "illustrations:generate": "tsx scripts/generate_illustrations.ts",
    "illustrations:guarantees": "tsx scripts/generate_guarantee_pngs.ts",
    "illustrations:guarantees:sym": "tsx scripts/generate_guarantee_sym_hero_pngs.ts",
    "illustrations:guarantees:sym:square": "tsx scripts/generate_guarantee_sym_square_icp_pngs.ts"
  },
  "mcpName": "io.github.markmhendrickson/neotoma",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "memory",
    "storage",
    "chatgpt"
  ],
  "author": "Mark Hendrickson",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/markmhendrickson/neotoma.git"
  },
  "homepage": "https://neotoma.io",
  "bugs": {
    "url": "https://github.com/markmhendrickson/neotoma/issues"
  },
  "openclaw": {
    "extensions": [
      "./dist/openclaw_entry.js"
    ],
    "compat": {
      "pluginApi": "2026.3.24-beta.2"
    },
    "build": {
      "openclawVersion": "2026.3.24-beta.2"
    }
  },
  "files": [
    "dist",
    "openapi.yaml",
    "openclaw.plugin.json",
    "skills",
    "LICENSE",
    "README.md"
  ],
  "dependencies": {
    "@hellocoop/httpsig": "^1.4.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@noble/curves": "^2.0.1",
    "@noble/hashes": "^2.0.1",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.0.6",
    "@radix-ui/react-label": "^2.0.2",
    "@radix-ui/react-navigation-menu": "^1.2.14",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.0.0",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toast": "^1.1.5",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@sqlite.org/sqlite-wasm": "^3.51.1-build1",
    "@tanstack/react-table": "^8.21.3",
    "@types/react-syntax-highlighter": "^15.5.13",
    "apache-arrow": "^21.1.0",
    "better-sqlite3": "^12.6.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.0",
    "commander": "^14.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "csv-parse": "^6.1.0",
    "dotenv": "^16.4.1",
    "express": "^4.21.2",
    "express-rate-limit": "^8.3.0",
    "helmet": "^7.2.0",
    "idb-keyval": "^6.2.2",
    "jose": "^6.2.2",
    "js-yaml": "^4.1.1",
    "lucide-react": "^0.344.0",
    "morgan": "^1.10.0",
    "openai": "^6.25.0",
    "openapi-fetch": "^0.15.0",
    "papaparse": "^5.5.3",
    "parquet-wasm": "^0.7.1",
    "pdf-parse": "^2.4.5",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-helmet-async": "^2.0.5",
    "react-icons": "^5.5.0",
    "react-router-dom": "^7.12.0",
    "react-syntax-highlighter": "^16.1.0",
    "semver": "^7.7.4",
    "simple-git": "^3.36.0",
    "sonner": "^2.0.7",
    "sqlite-vec": "^0.1.6",
    "tailwind-merge": "^2.2.0",
    "tailwindcss-animate": "^1.0.7",
    "turndown": "^7.2.4",
    "turndown-plugin-gfm": "^1.0.2",
    "typewriter-effect": "^2.22.0",
    "ws": "^8.18.0",
    "zod": "^3.22.4"
  },
  "overrides": {
    "hono": "^4.12.7",
    "@hono/node-server": "^1.19.10",
    "fast-xml-parser": "^5.4.1",
    "flatted": "^3.4.2",
    "qs": "^6.15.0"
  },
  "devDependencies": {
    "@fal-ai/client": "^1.9.5",
    "@playwright/test": "^1.56.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.25",
    "@types/js-yaml": "^4.0.9",
    "@types/morgan": "^1.9.7",
    "@types/node": "^20.10.6",
    "@types/pdf-parse": "^1.1.5",
    "@types/pdfkit": "^0.17.3",
    "@types/react": "^18.2.45",
    "@types/react-dom": "^18.2.18",
    "@types/semver": "^7.7.1",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.16",
    "baseline-browser-mapping": "^2.9.15",
    "concurrently": "^8.2.2",
    "cross-env": "^10.1.0",
    "eslint": "^8.56.0",
    "husky": "^9.1.7",
    "jsdom": "^27.2.0",
    "lint-staged": "^16.2.7",
    "openapi-typescript": "^7.10.1",
    "pdfkit": "^0.17.2",
    "postcss": "^8.4.32",
    "prettier": "^3.7.4",
    "sharp": "^0.33.5",
    "tailwindcss": "^3.4.0",
    "tsx": "^4.7.1",
