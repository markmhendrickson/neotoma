{
  "version": 1,
  "description": "Fix-keyword / surface-name → upgrade_guidance template, consulted by the feedback ingest cron and triage skill. Maintained as part of the release ritual — each shipped fix that closes a feedback kind should add or update an entry here.",
  "entries": [
    {
      "keywords": ["store --plan", "plan dry run", "dry-run"],
      "surface_names": ["store --plan", "store_structured plan"],
      "guidance": {
        "target_version": "0.5.0",
        "min_version_including_fix": "0.5.0",
        "release_url": "https://github.com/markmhendrickson/neotoma/releases/tag/v0.5.0",
        "install_commands": {
          "neotoma_cli": "npm i -g neotoma@0.5.0",
          "neotoma_client_ts": "npm i neotoma-client@0.5.0",
          "neotoma_client_python": "pip install neotoma-client==0.5.0"
        },
        "restart_required": true,
        "verification_steps": [
          "neotoma store --plan --json ... — confirm plan output with no side effects"
        ],
        "usage_example": ["neotoma store --plan --json --entities '[...]'"],
        "new_surfaces": [
          { "kind": "cli_flag", "name": "--plan", "summary": "Dry-run preview for store" }
        ],
        "action_required": "upgrade_and_use_new_surface"
      }
    },
    {
      "keywords": ["store --strict", "strict mode"],
      "surface_names": ["store --strict"],
      "guidance": {
        "target_version": "0.5.0",
        "min_version_including_fix": "0.5.0",
        "release_url": "https://github.com/markmhendrickson/neotoma/releases/tag/v0.5.0",
        "install_commands": {
          "neotoma_cli": "npm i -g neotoma@0.5.0",
          "neotoma_client_ts": "npm i neotoma-client@0.5.0"
        },
        "verification_steps": [
          "neotoma store --strict --json ... — confirms silent merges fail loudly"
        ],
        "usage_example": ["neotoma store --strict --json --entities '[...]'"],
        "new_surfaces": [
          { "kind": "cli_flag", "name": "--strict", "summary": "Refuse silent merges in store" }
        ],
        "action_required": "upgrade_and_use_new_surface"
      }
    },
    {
      "keywords": ["neotoma ingest", "ingest verb", "dedicated ingest"],
      "surface_names": ["ingest"],
      "guidance": {
        "target_version": "0.5.0",
        "min_version_including_fix": "0.5.0",
        "release_url": "https://github.com/markmhendrickson/neotoma/releases/tag/v0.5.0",
        "install_commands": { "neotoma_cli": "npm i -g neotoma@0.5.0" },
        "verification_steps": ["neotoma ingest --help"],
        "usage_example": ["neotoma ingest --path ./file.json"],
        "new_surfaces": [
          { "kind": "cli_flag", "name": "ingest", "summary": "Dedicated ingest verb" }
        ],
        "action_required": "upgrade_and_use_new_surface"
      }
    },
    {
      "keywords": ["entity_snapshot_after", "resolver_path", "store response shape"],
      "surface_names": ["store response"],
      "guidance": {
        "target_version": "0.5.0",
        "min_version_including_fix": "0.5.0",
        "release_url": "https://github.com/markmhendrickson/neotoma/releases/tag/v0.5.0",
        "install_commands": {
          "neotoma_cli": "npm i -g neotoma@0.5.0",
          "neotoma_client_ts": "npm i neotoma-client@0.5.0"
        },
        "verification_steps": [
          "Inspect store response — entity_snapshot_after, resolver_path, and action should be populated per entity"
        ],
        "usage_example": [
          "const res = await client.store({...}); console.log(res.entities[0].entity_snapshot_after, res.entities[0].resolver_path);"
        ],
        "new_surfaces": [
          { "kind": "response_field", "name": "entity_snapshot_after", "summary": "Post-store snapshot" },
          { "kind": "response_field", "name": "resolver_path", "summary": "Resolution trace" },
          { "kind": "response_field", "name": "action", "summary": "created | updated | merged per entity" }
        ],
        "migration_notes": "Pre-0.5.0 clients reading the flat attributes wrapper must update to read entities[].entity_snapshot_after.",
        "breaking_change": true,
        "action_required": "upgrade_and_retry"
      }
    },
    {
      "keywords": ["list_recent_changes", "recent changes"],
      "surface_names": ["list_recent_changes"],
      "guidance": {
        "target_version": "0.5.0",
        "min_version_including_fix": "0.5.0",
        "release_url": "https://github.com/markmhendrickson/neotoma/releases/tag/v0.5.0",
        "install_commands": { "neotoma_cli": "npm i -g neotoma@0.5.0" },
        "verification_steps": ["neotoma list-recent-changes --limit 10"],
        "usage_example": ["neotoma list-recent-changes --limit 50"],
        "new_surfaces": [
          { "kind": "mcp_tool", "name": "list_recent_changes", "summary": "Recent activity across core tables" }
        ],
        "action_required": "upgrade_and_use_new_surface"
      }
    },
    {
      "keywords": ["NEOTOMA_BASE_URL", "NEOTOMA_API_ONLY"],
      "surface_names": ["env: NEOTOMA_BASE_URL", "env: NEOTOMA_API_ONLY"],
      "guidance": {
        "target_version": "0.5.0",
        "min_version_including_fix": "0.5.0",
        "release_url": "https://github.com/markmhendrickson/neotoma/releases/tag/v0.5.0",
        "install_commands": { "neotoma_cli": "npm i -g neotoma@0.5.0" },
        "verification_steps": ["NEOTOMA_BASE_URL=... NEOTOMA_API_ONLY=1 neotoma entities search ..."],
        "usage_example": ["export NEOTOMA_BASE_URL=https://api.neotoma.io; export NEOTOMA_API_ONLY=1"],
        "new_surfaces": [
          { "kind": "env_var", "name": "NEOTOMA_BASE_URL", "summary": "Override CLI base URL" },
          { "kind": "env_var", "name": "NEOTOMA_API_ONLY", "summary": "Force CLI through HTTP API, no local SQLite" }
        ],
        "action_required": "upgrade_and_use_new_surface"
      }
    },
    {
      "keywords": ["searchable_fields"],
      "surface_names": ["schema searchable_fields"],
      "guidance": {
        "target_version": "0.5.0",
        "min_version_including_fix": "0.5.0",
        "release_url": "https://github.com/markmhendrickson/neotoma/releases/tag/v0.5.0",
        "install_commands": { "neotoma_cli": "npm i -g neotoma@0.5.0" },
        "verification_steps": [
          "Register a schema with searchable_fields and verify retrieve_entity_by_identifier matches across them"
        ],
        "usage_example": [
          "register_schema { searchable_fields: ['name', 'aliases'] }"
        ],
        "new_surfaces": [
          { "kind": "response_field", "name": "searchable_fields", "summary": "Schema hint for identifier lookup" }
        ],
        "action_required": "upgrade_and_use_new_surface"
      }
    },
    {
      "keywords": ["CanonicalNameUnresolvedError", "canonical name"],
      "surface_names": ["CanonicalNameUnresolvedError"],
      "guidance": {
        "target_version": "0.5.0",
        "min_version_including_fix": "0.5.0",
        "release_url": "https://github.com/markmhendrickson/neotoma/releases/tag/v0.5.0",
        "install_commands": { "neotoma_cli": "npm i -g neotoma@0.5.0" },
        "verification_steps": [
          "Submit a store request without identifying fields and confirm CanonicalNameUnresolvedError is returned with actionable hints"
        ],
        "usage_example": [
          "// When you see CanonicalNameUnresolvedError, add canonical_name or a field listed under searchable_fields."
        ],
        "action_required": "behavior_change_only"
      }
    },
    {
      "keywords": ["find-duplicates", "list_potential_duplicates"],
      "surface_names": ["list_potential_duplicates"],
      "guidance": {
        "target_version": "0.5.0",
        "min_version_including_fix": "0.5.0",
        "release_url": "https://github.com/markmhendrickson/neotoma/releases/tag/v0.5.0",
        "install_commands": { "neotoma_cli": "npm i -g neotoma@0.5.0" },
        "verification_steps": ["neotoma find-duplicates --entity-type person"],
        "usage_example": ["neotoma find-duplicates --entity-type contact"],
        "new_surfaces": [
          { "kind": "mcp_tool", "name": "list_potential_duplicates", "summary": "Surface likely duplicate entities" }
        ],
        "action_required": "upgrade_and_use_new_surface"
      }
    },
    {
      "keywords": ["include_observations", "identifier include_observations"],
      "surface_names": ["retrieve_entity_by_identifier include_observations"],
      "guidance": {
        "target_version": "0.5.0",
        "min_version_including_fix": "0.5.0",
        "release_url": "https://github.com/markmhendrickson/neotoma/releases/tag/v0.5.0",
        "install_commands": { "neotoma_cli": "npm i -g neotoma@0.5.0" },
        "verification_steps": [
          "retrieve_entity_by_identifier { include_observations: true } — ensure observations array is returned"
        ],
        "usage_example": [
          "retrieve_entity_by_identifier({ identifier: 'foo', include_observations: true })"
        ],
        "new_surfaces": [
          { "kind": "response_field", "name": "include_observations", "summary": "Inline observations on identifier lookup" }
        ],
        "action_required": "upgrade_and_use_new_surface"
      }
    },
    {
      "keywords": ["--since", "updated_since", "since filter"],
      "surface_names": ["retrieve_entities updated_since"],
      "guidance": {
        "target_version": "0.5.0",
        "min_version_including_fix": "0.5.0",
        "release_url": "https://github.com/markmhendrickson/neotoma/releases/tag/v0.5.0",
        "install_commands": { "neotoma_cli": "npm i -g neotoma@0.5.0" },
        "verification_steps": ["neotoma entities list --since 2026-04-01"],
        "usage_example": ["retrieve_entities({ updated_since: '2026-04-01' })"],
        "new_surfaces": [
          { "kind": "response_field", "name": "updated_since", "summary": "Filter entities by updated_at" }
        ],
        "action_required": "upgrade_and_use_new_surface"
      }
    }
  ]
}
