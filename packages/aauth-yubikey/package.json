{
  "name": "@neotoma/aauth-yubikey",
  "version": "0.1.0",
  "private": true,
  "description": "Optional cross-platform YubiKey native binding for Neotoma AAuth. Generates PIV slot 9c-resident keys via the Yubico PKCS#11 provider (libykcs11) and produces WebAuthn-`packed`-format attestation envelopes via the YKPIV_INS_ATTEST APDU for the AAuth `cnf.attestation` claim.",
  "type": "commonjs",
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "files": [
    "lib",
    "src",
    "binding.gyp",
    "prebuilds",
    "README.md",
    "LICENSE"
  ],
  "os": [
    "darwin",
    "linux",
    "win32"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "build:native": "node-gyp rebuild",
    "prebuild": "prebuildify --napi --strip",
    "install": "node-gyp-build || true",
    "test": "node --test tests/"
  },
  "keywords": [
    "neotoma",
    "aauth",
    "yubikey",
    "yubico",
    "piv",
    "pkcs11",
    "attestation",
    "webauthn-packed"
  ],
  "author": "Mark Hendrickson",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/markmhendrickson/neotoma.git",
    "directory": "packages/aauth-yubikey"
  },
  "homepage": "https://neotoma.io",
  "bugs": {
    "url": "https://github.com/markmhendrickson/neotoma/issues"
  },
  "dependencies": {
    "node-addon-api": "^7.1.0",
    "node-gyp-build": "^4.8.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.6",
    "node-gyp": "^10.0.0",
    "prebuildify": "^6.0.0",
    "typescript": "^5.3.3"
  }
}
