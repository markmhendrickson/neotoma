{
  "name": "neotoma",
  "version": "0.1.1",
  "description": "Harness-specific lifecycle hooks + portable Neotoma access. MCP/CLI work in any agent environment; this artifact is the Claude Code plugin (Python hooks under ${CLAUDE_PLUGIN_ROOT}). The same package also ships a Cursor hook map (.cursor/hooks.json → cursor-hooks) with the same goals but different lifecycle names (e.g. PreCompact is Claude Code–only here). Retrieval injection, tool-call logging, compaction markers where supported, stop-turn persistence safety net — complements MCP (hooks are not MCP tools).",
  "author": {
    "name": "Mark Hendrickson",
    "url": "https://neotoma.io"
  },
  "homepage": "https://neotoma.io",
  "repository": "https://github.com/markmhendrickson/neotoma",
  "license": "MIT",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/hooks/session_start.py\""
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/hooks/user_prompt_submit.py\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/hooks/post_tool_use.py\""
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/hooks/pre_compact.py\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/hooks/stop.py\""
          }
        ]
      }
    ]
  }
}
